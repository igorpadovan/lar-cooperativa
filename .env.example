# Copie este arquivo para .env e ajuste os valores conforme necessário.

# PostgreSQL
POSTGRES_USER=lar
POSTGRES_PASSWORD=lar
POSTGRES_DB=lar_cooperativa

# Portas expostas no host
POSTGRES_HOST_PORT=5433
API_HOST_PORT=8081

# Autenticação (JWT_KEY precisa ter ao menos 32 caracteres)
JWT_KEY=chave-de-desenvolvimento-nao-usar-em-producao-0123456789
ADMIN_USUARIO=admin
ADMIN_SENHA=admin123
